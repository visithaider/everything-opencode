{
  "name": "eoc-opencode",
  "version": "1.0.3",
  "description": "Everything OpenCode - OpenCode Plugin with agents, commands, skills, hooks, and rules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "eoc-opencode": "./cli.js",
    "eoc-opencode-install": "./install.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "prompts",
    "instructions",
    "opencode.json",
    "agents",
    "commands",
    "skills",
    "hooks",
    "cli.js",
    "install.js"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.3.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ai",
    "agents",
    "development",
    "automation"
  ],
  "author": "Haider Ali - (visithaider)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/visithaider/everything-opencode"
  },
  "engines": {
    "opencode": ">=1.8.0"
  },
  "opencode": {
    "plugins": ["dist/index.js"]
  }
}